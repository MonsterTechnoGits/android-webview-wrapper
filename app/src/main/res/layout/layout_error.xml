<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/errorLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fillViewport="true"
    android:visibility="gone">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingVertical="48dp">

        <!-- Animated error icon container -->
        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp">

            <!-- Soft background circle -->
            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_error_circle" />

            <ImageView
                android:id="@+id/errorIcon"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:contentDescription="Error icon"
                android:src="@drawable/ic_wifi_off"
                app:tint="@color/error_icon_tint" />
        </FrameLayout>

        <!-- Error badge / pill -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_error_badge"
            android:paddingHorizontal="14dp"
            android:paddingVertical="4dp"
            android:text="Something went wrong"
            android:textColor="@color/error_badge_text"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <!-- Main title — plain language -->
        <TextView
            android:id="@+id/errorTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="We couldn't connect to the internet"
            android:textColor="?attr/colorOnSurface"
            android:textSize="22sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.3" />

        <!-- Friendly explanation -->
        <TextView
            android:id="@+id/errorMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Your device isn't connected to the internet right now. This can happen when Wi-Fi or mobile data is turned off."
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.5" />

        <!-- Step-by-step help card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Here's what you can do:"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="14dp" />

                <!-- Step 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_step_number"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="?attr/colorOnPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Check if Wi-Fi or mobile data is turned on in your Settings"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>

                <!-- Step 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_step_number"
                        android:gravity="center"
                        android:text="2"
                        android:textColor="?attr/colorOnPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Move closer to your Wi-Fi router if the signal is weak"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>

                <!-- Step 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_step_number"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="?attr/colorOnPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Then tap the button below to try loading again"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Primary retry button — large, accessible touch target -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/retryButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:text="Try Again"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_refresh"
            app:iconGravity="textStart"
            app:iconPadding="8dp" />

        <!-- Secondary: open device settings shortcut -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/openSettingsButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="Open Network Settings"
            android:textSize="14sp"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_settings"
            app:iconGravity="textStart"
            app:iconPadding="8dp" />

        <!-- Error code for support (dimmed, unobtrusive) -->
        <TextView
            android:id="@+id/errorCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:alpha="0.4"
            android:text="Error code: ERR_CONNECTION"
            android:textColor="?attr/colorOnSurface"
            android:textSize="11sp"
            android:fontFamily="monospace" />

    </LinearLayout>
</ScrollView>
